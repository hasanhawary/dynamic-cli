{
  "name": "hasanhawary/dynamic-cli",
  "description": "A Laravel package providing a dynamic CLI scaffolder for CRUD generation (skeleton).",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "laravel",
    "cli",
    "crud",
    "generator",
    "scaffolding"
  ],
  "authors": [
    {
      "name": "Hasan Hawary",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.2",
    "illuminate/support": "^10.0 || ^11.0 || ^12.0 || ^13.0",
    "illuminate/console": "^10.0 || ^11.0 || ^12.0 || ^13.0",
    "hasanhawary/lookup-manager": "^1.0",
    "hasanhawary/media-manager": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "HasanHawary\\DynamicCli\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "HasanHawary\\DynamicCli\\DynamicCliServiceProvider"
      ]
    }
  },
  "bin": [
    "bin/dynamic-cli"
  ],
  "homepage": "https://github.com/hasanhawary/dynamic-cli",
  "support": {
    "issues": "https://github.com/hasanhawary/dynamic-cli/issues",
    "source": "https://github.com/hasanhawary/dynamic-cli"
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}